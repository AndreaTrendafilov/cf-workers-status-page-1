  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--openssl-legacy-provider flareact dev",
    "build": "npm run css && NODE_OPTIONS=--openssl-legacy-provider flareact build",
    "deploy": "npm run build && NODE_OPTIONS=--openssl-legacy-provider flareact publish",
    "kv-gc": "node ./src/cli/gcMonitors.js",
