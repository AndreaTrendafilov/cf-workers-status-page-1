{
  "name": "cf-workers-status-page",
  "version": "1.0.0",
  "author": "Adam Janiš <adam.janis@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "predev": "node scripts/emit-config.mjs",
    "dev": "npm run css && astro dev",
    "prebuild": "node scripts/emit-config.mjs",
    "build": "NODE_ENV=production npm run css && astro build && npx esbuild src/cron/bundle-entry.js --bundle --platform=neutral --target=es2022 --format=esm --outfile=dist/server/cron-bundle.mjs && node scripts/write-cloudflare-worker.mjs",
    "deploy": "npm run build && wrangler deploy --env production",
    "kv-gc": "node ./src/cli/gcMonitors.js",
    "format": "prettier --write '**/*.{js,css,json,md}'",
    "css": "postcss public/tailwind.css -o public/style.css"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "laco": "^1.2.1",
    "laco-react": "^1.1.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^13.1.9",
    "@astrojs/react": "^5.0.3",
    "astro": "^6.1.6",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^2.2.19",
    "typescript": "^6.0.2",
    "wrangler": "^4.83.0",
    "yaml": "^2.6.1"
  }
}
