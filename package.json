    "react-dom": "^17.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^2.2.19",
    "yaml": "^2.6.1",
    "yaml-loader": "^0.6.0"
  }
}
